{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,

    /* composite: true 설정 시 noEmit은 false여야 하며, 대신 emitDeclarationOnly를 true로 설정하여 타입 선언 파일만 생성 */
    "noEmit": false,
    "emitDeclarationOnly": true,

    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "composite": true,
    "declaration": true,
    /* 참조 시 소스 맵 연동을 위해 추가 */
    "declarationMap": true,
    "rootDir": "src"
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"],
  "references": [{ "path": "../api-interface" }]
}
