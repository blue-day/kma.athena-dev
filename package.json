{
  "name": "kma-monorepo",
  "version": "1.0.0",
  "private": true,
  "description": "KMA Hybrid Monorepo (React + NestJS + Solutions)",
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "codegen": "turbo run codegen",
    "clean": "turbo run clean && rm -rf node_modules",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "tool:repomix": "repomix --config tools/config/repomix.config.json"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^16.1.6",
    "@types/node": "^22.13.0",
    "@types/prismjs": "^1.26.5",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "cross-env": "^10.1.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "^10.0.2",
    "eslint-config-next": "^16.1.6",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "prettier": "^3.8.1",
    "repomix": "^1.11.1",
    "turbo": "latest",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "dependencies": {
    "next": "16.1.6"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.4",
      "react-dom": "19.2.4",
      "@types/react": "^19.0.0",
      "@types/react-dom": "^19.0.0"
    }
  }
}
