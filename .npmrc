# --- 기존 로컬 환경 설정 (주석 처리) ---
# # 스코프 강제
# # @kma:registry=http://localhost:8081/repository/npm-private/
# 
# # 인증 강제 + 항상 인증 사용
# # login 하면 자동 채워짐
# # //localhost:8081/repository/npm-private/:_auth=YWRtaW46bmV4dXNhZG1pbjE=
# # //localhost:8081/repository/npm-private/:_always-auth=true
# 
# # 불필요한 경고 줄이기
# # engine-strict=false


# --- 신규 AWS 환경 설정 ---
# 스코프 강제 (@kma 패키지는 내부 AWS 넥서스를 바라보도록 라우팅)
@kma:registry=https://nexus.kma.ninja/repository/npm-private/

# 인증 강제 + 항상 인증 사용
//nexus.kma.ninja/repository/npm-private/:_auth=YWRtaW46bmV4dXNhZG1pbjE=
//nexus.kma.ninja/repository/npm-private/:_always-auth=true

# 불필요한 경고 줄이기
engine-strict=false